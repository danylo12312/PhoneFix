<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_variant"
    android:fillViewport="true"
    tools:context=".ui.repairs.RepairDetailActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ════════ Градієнтний заголовок ════════ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_gradient">

            <!-- Декоративне коло -->
            <View
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_gravity="end"
                android:layout_marginTop="-40dp"
                android:layout_marginEnd="-20dp"
                android:background="@drawable/bg_circle_decorative" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="48dp"
                android:paddingBottom="24dp">

                <!-- Кнопка «Назад» -->
                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_back_button_light"
                    android:padding="6dp"
                    android:src="@drawable/ic_arrow_back_white"
                    android:contentDescription="Назад" />

                <!-- Бренд + Модель -->
                <TextView
                    android:id="@+id/tvPhoneTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:textColor="@android:color/white"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    tools:text="Samsung Galaxy S23" />

                <!-- Дата створення -->
                <TextView
                    android:id="@+id/tvCreatedDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#B3FFFFFF"
                    android:textSize="14sp"
                    tools:text="Створено: 01.04.2026" />

                <!-- Бейдж статусу -->
                <TextView
                    android:id="@+id/tvStatusBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="25dp"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:paddingHorizontal="14dp"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="Новий" />

            </LinearLayout>
        </FrameLayout>

        <!-- ════════ Кнопки зміни статусу ════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnStatusNew"
                android:layout_width="0dp"
                android:layout_height="39dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/status_new"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnStatusInProgress"
                android:layout_width="0dp"
                android:layout_height="39dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:gravity="center"
                android:text="@string/status_in_progress"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnStatusDone"
                android:layout_width="0dp"
                android:layout_height="39dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:gravity="center"
                android:text="@string/status_done"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnStatusDelivered"
                android:layout_width="0dp"
                android:layout_height="39dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:gravity="center"
                android:text="@string/status_delivered"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ════════ Картка інформації про ремонт ════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/outline"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- IMEI -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IMEI"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvImei"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    tools:text="354678901234567" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="12dp"
                    android:background="@color/divider" />

                <!-- Опис несправності -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Опис несправності"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvProblem"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    tools:text="Розбитий екран, не реагує на дотик" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="12dp"
                    android:background="@color/divider" />

                <!-- Виконані роботи -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Виконані роботи"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvWorkDone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    tools:text="Заміна дисплейного модуля" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="12dp"
                    android:background="@color/divider" />

                <!-- Ціна -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Вартість ремонту"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="4 500 грн" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ════════ Блок клієнта ════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardClient"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="10dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/outline"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <!-- Аватар -->
                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_avatar_circle">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_person_small"
                        android:contentDescription="@null" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvClientName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        tools:text="Олександр Петренко" />

                    <TextView
                        android:id="@+id/tvClientPhone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        tools:text="+380501234567" />
                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    android:contentDescription="@null" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ════════ Кнопки дій ════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            android:orientation="horizontal">

            <!-- Редагувати -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEdit"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="43dp"
                android:layout_weight="1"
                android:text="Редагувати"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="8dp"
                app:strokeColor="@color/outline" />

            <View android:layout_width="10dp" android:layout_height="0dp" />

            <!-- Змінити статус -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNextStatus"
                android:layout_width="0dp"
                android:layout_height="43dp"
                android:layout_weight="1"
                android:backgroundTint="@color/primary"
                android:text="Наступний статус"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="8dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
